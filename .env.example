# --- Groq (LLM for generating the briefing summary) ---
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# --- Resend (primary email transport) ---
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
# The verified "from" address on your Resend domain (e.g. briefing@yourdomain.com)
RESEND_FROM=briefing@yourdomain.com
# The address that should receive the morning briefing
RESEND_TO=you@yourdomain.com

# --- Gmail / Nodemailer (optional secondary transport) ---
# The Gmail account you want to send from
GMAIL_USER=you@gmail.com
# An App Password (not your normal password) generated at https://myaccount.google.com/apppasswords
GMAIL_PASS=your_gmail_app_password

# --- Supabase (production data source for real mode) ---
# Your Supabase project URL (Settings > API > Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role key OR anon key with read access to the signups table (Settings > API > Project API keys)
SUPABASE_KEY=your_supabase_key_here
# Name of the table holding signups (default: signups)
SUPABASE_SIGNUPS_TABLE=signups
# Column on that table that holds the signup timestamp (default: created_at)
SUPABASE_SIGNUPS_TIMESTAMP_COLUMN=created_at

# --- Runtime ---
# "demo" uses the sample leads from src/leads.js; "real" pulls yesterday's signups from Supabase
BRIEFING_MODE=demo
# IANA timezone used by the cron scheduler AND for computing "yesterday" boundaries
# (e.g. America/New_York, Europe/London, Asia/Manila, Asia/Singapore)
SCHEDULE_TZ=America/New_York

# --- Deployment (only needed if hosting the cron endpoint on Vercel) ---
# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>` to protect the endpoint
CRON_SECRET=generate_a_long_random_string_here
